# Copy to .env and fill in. Never commit .env. See docs/INFRASTRUCTURE.md.

# App — canonical public origin. Used to build absolute links in emails (the
# new-issue magic link and the unsubscribe link). Optional: falls back to the
# request Host when unset. In production set it to the real site URL so emailed
# links point at the right host regardless of which host the admin published from.
APP_URL=http://localhost:3000

# Branding (public — shown in the UI, safe to expose)
NEXT_PUBLIC_MAGAZINE_NAME="The Magazine"
NEXT_PUBLIC_ORG_NAME="Your Club"
NEXT_PUBLIC_TAGLINE="A members-only digital magazine."

# Brand skin — the app-wide palette (visual identity), one of the brands defined
# in src/lib/brands.ts + src/app/brands.css. Optional; defaults to "heritage"
# (the warm-paper/green look). Build-time inlined, so changing it needs a rebuild
# (same as the branding text above). An unknown value fails the build/boot.
# NEXT_PUBLIC_BRAND=heritage

# Layout themes offered to the admin editor + reader — a comma list of theme ids
# from the registry (src/features/blocks/themes). Optional; unset = all
# ("classic,modern"). Existing issues authored under a now-excluded theme still
# render. Build-time inlined; unknown ids fail the build/boot.
# NEXT_PUBLIC_ISSUE_THEMES=classic,modern

# Demo mode — ungates the library and reader (`/`, `/read/*`) for a public
# showcase deployment; `/admin/*`, server actions and uploads stay locked.
# NEVER set this on the real members' site. Build-time inlined (it must be
# present when the image builds, not just at runtime — Railway: set it on the
# demo project before deploying). Off unless exactly "1".
# NEXT_PUBLIC_DEMO_MODE=1

# Auth.js — generate with: npx auth secret. Needed even in dev (sign-in
# won't start without it); required in production.
AUTH_SECRET=

# Auth.js — the public origin Auth.js stamps into the sign-in magic link.
# In production set this to the real https site URL (e.g. https://demo.octavo.dev).
# Unset, Auth.js derives the origin from the request Host, which behind a proxy can
# come out as an internal address (e.g. http://localhost:8080, the container's PORT)
# and make the emailed link unclickable. Distinct from APP_URL above, which only
# covers the blast/unsubscribe links. Fine to leave unset in local dev.
# AUTH_URL=http://localhost:3000

# Database (Railway Postgres)
DATABASE_URL=

# Cloudflare R2 (S3-compatible) — optional in dev (falls back to local disk),
# required in production (the app refuses to boot without it)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Email (Resend) — optional in dev (magic links are logged to the dev-server
# console instead), required in production. EMAIL_FROM must be on a domain
# verified in Resend.
EMAIL_API_KEY=
EMAIL_FROM="Club Magazine <hello@example.org>"

# Sentry error reporting — optional everywhere (the app boots and runs fine
# with these unset; Sentry is simply a no-op). Set both to the SAME DSN from
# your Sentry project: SENTRY_DSN is read server-side, NEXT_PUBLIC_SENTRY_DSN
# is the browser copy (a DSN is a public ingest key, not a secret — and it is
# build-time inlined, so it must be present in the build environment). See
# docs/infrastructure.md for the owner setup + alert-rule checklist.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
